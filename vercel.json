{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/downloads/:path*",
      "destination": "https://raw.githubusercontent.com/JoshElieson/pe-web/main/public/downloads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/downloads/(.*\\.(exe|msi))",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
